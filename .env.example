# --- Platform authentication (REQUIRED in production) ---
# Set in Railway Variables — never commit real values to git.
AUTH_USERNAME=your_username
AUTH_PASSWORD=your_strong_password
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SESSION_SECRET=replace_with_64_char_hex_secret_minimum_32_chars
# true on Railway (HTTPS); false for local http://127.0.0.1
AUTH_COOKIE_SECURE=false
SESSION_INACTIVITY_MINUTES=30
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=30
# Local only: allow ephemeral session secret if AUTH_SESSION_SECRET unset
# AUTH_ALLOW_DEV_DEFAULTS=false
# Raw seller debug API (disabled by default in production)
# ENABLE_SELLER_DEBUG_ENDPOINT=false

ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5
HEADLESS=0
DEBUG=1
MAX_SOURCES=5
SEARCH_TIMEOUT_MS=10000
FETCH_TIMEOUT_MS=10000
CLAUDE_TIMEOUT_SEC=30
EXCERPT_MAX_CHARS=4500

# --- Seller Intelligence V1 ---
USD_PHP_RATE=61.55

# --- Seller Dashboard: Google Sheets (mirror, Service Account) ---
# See GOOGLE_SHEETS_SETUP.md. Keep ENABLED=false until live connection is approved.
GOOGLE_SHEETS_ENABLED=true
GOOGLE_SHEET_MIRROR_ID=1uhq7vJqLSDbckeLHf2SxEjEloMHb-xLa8YimGCs9Eyk
# Local dev: path to JSON key (gitignored under credentials/)
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/service-account.json
# Railway: paste full Service Account JSON as one line (do not use both path and JSON in prod)
# GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SCOPES=https://www.googleapis.com/auth/spreadsheets.readonly
GOOGLE_SHEET_PRIMARY_TAB=AI DATA
# Seller Intelligence V1 master list tab (columns: Shop ID, Shop Name, Shopee Link, TikTok Shop Name)
GOOGLE_SHEET_SELLER_MASTER_TAB=shpoee link
# Shopee ADGMV Tracker tab (columns: shop_name, mtd_adgmv_usd, m_1_adgmv_usd)
GOOGLE_SHEET_SHOPEE_ADGMV_TAB=shopee adgmv raw data
GOOGLE_SHEETS_CONNECT_ON_STARTUP=false
